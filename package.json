{
  "name": "opentrader",
  "version": "0.0.0",
  "private": true,
  "description": "Multi-broker trading dashboard inspired by Robinhood Legend",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "concurrently -n sidecar,tauri -c blue,magenta --kill-others-on-fail \"pnpm sidecar:dev\" \"pnpm tauri:dev\"",
    "dev:web": "concurrently -n sidecar,vite -c blue,green --kill-others-on-fail \"pnpm sidecar:dev\" \"pnpm --filter @opentrader/desktop dev:vite\"",
    "sidecar:dev": "pnpm --filter @opentrader/sidecar dev",
    "tauri": "pnpm --filter @opentrader/desktop tauri",
    "tauri:dev": "pnpm --filter @opentrader/desktop tauri dev",
    "tauri:build": "pnpm --filter @opentrader/desktop tauri build",
    "build": "pnpm -r --filter='./packages/*' build && pnpm --filter @opentrader/desktop build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,css}\""
  },
  "devDependencies": {
    "concurrently": "9.2.1",
    "prettier": "3.8.3",
    "typescript": "6.0.3"
  }
}
