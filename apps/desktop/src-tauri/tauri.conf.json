{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "opentrader",
  "version": "0.0.0",
  "identifier": "com.andavin.opentrader",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "opentrader",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0d0c0e",
        "shadow": true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.png"],
    "category": "Finance",
    "shortDescription": "Multi-broker trading dashboard",
    "longDescription": "opentrader: a Robinhood-Legend-style desktop dashboard for trading across Alpaca, Robinhood, and Fidelity from a single workspace."
  }
}
