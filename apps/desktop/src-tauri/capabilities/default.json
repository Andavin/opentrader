{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-fullscreen",
    "core:window:allow-toggle-maximize",
    "core:window:allow-minimize",
    "shell:allow-open",
    "store:default",
    "os:default",
    "dialog:default"
  ]
}
