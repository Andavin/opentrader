# opentrader sidecar — local dev defaults
# Copy to .env and fill in your own values.

PORT=1421
HOST=127.0.0.1

# Shared bearer token between sidecar and frontend.
# In production the Tauri shell mints a fresh token on startup and
# passes it to both processes; here we pin a dev-only value so you can
# curl the sidecar directly while iterating.
OPENTRADER_SIDECAR_TOKEN=dev-token-change-in-prod

LOG_LEVEL=info
